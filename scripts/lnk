#!/usr/bin/sh
set -eu

# 默认目标目录
TARGET_DIR="$HOME/.local/bin"

usage() {
    cat << EOF
用法: $(basename "$0") [文件...] [-t 目标目录] [-h]

快速将文件创建软链接（Symbolic Link）到指定目录。

选项:
  -t    指定目标目录 (默认: $HOME/.local/bin)
  -h    显示此帮助信息

示例:
  $(basename "$0") my_script.sh              # 链接到 ~/.local/bin
  $(basename "$0") tool.py -t /usr/local/bin # 链接到指定目录
EOF
}

# 解析参数
# 使用 getopts 处理 -t 和 -h
while getopts "t:h" opt; do
    case "$opt" in
        t) TARGET_DIR="$OPTARG" ;;
        h) usage; exit 0 ;;
        *) usage; exit 1 ;;
    esac
done

# 移除已处理的选项参数，剩下的是文件列表
shift $((OPTIND - 1))

# 检查是否有输入文件
if [ $# -eq 0 ]; then
    echo "错误: 未指定文件。"
    usage
    exit 1
fi

# 检查目标目录是否存在
if [ ! -d "$TARGET_DIR" ]; then
    echo "目录 $TARGET_DIR 不存在，正在创建..."
    mkdir -p "$TARGET_DIR"
fi

# 循环处理所有传入的文件
for file in "$@"; do
    if [ -e "$file" ]; then
        # 获取文件的绝对路径和文件名
        abs_path=$(realpath "$file")
        file_name=$(basename "$file")

        # 执行链接
        ln -snf "$abs_path" "$TARGET_DIR/$file_name"
        echo "已链接: $file_name -> $TARGET_DIR"
    else
        echo "跳过: 文件 '$file' 不存在。"
    fi
done
